" 
" [ Plugins installed on nvim ] - Place 'plug.vim' from vim-plug in /nvim/autoload directory
" 

call plug#begin() 

" Shows vim modes in status bar
Plug 'https://github.com/itchyny/lightline.vim'

" Themes [options=> dracula, iceberg, ayu-vim, oceanic-next, nord-vim]
Plug 'dracula/vim', { 'as': 'dracula' }
Plug 'cocopon/iceberg.vim'
Plug 'morhetz/gruvbox'

" File Explorer
Plug 'preservim/nerdtree'

" Telescope for file search
Plug 'nvim-lua/plenary.nvim'
Plug 'nvim-telescope/telescope.nvim', { 'tag': '0.1.x' }


" Editor config
Plug 'editorconfig/editorconfig-vim'

" Javascript syntax highlighting
Plug 'https://github.com/pangloss/vim-javascript.git'
" Plug 'sheerun/vim-polyglot'

" Jaavascript intellsense: coc-json, coc-tsserver, coc-eslint
Plug 'neoclide/coc.nvim', {'branch': 'release'}

" Git 
" modified/deleted line indicators
Plug 'https://github.com/airblade/vim-gitgutter.git'
Plug 'Xuyuanp/nerdtree-git-plugin'
Plug 'tpope/vim-fugitive'

" Creates closing brackets automatically
Plug 'windwp/nvim-autopairs'

call plug#end()

" ----------------------------------------------------------------------------

" [ Plugin configuration ]

" Open FzF in down split with 40% screen size
let g:fzf_layout = { 'down': '40%' }

" coc global extension names to install when they aren't installed.
let g:coc_global_extensions = ['coc-json','coc-tsserver','coc-eslint','coc-prettier','coc-docker']

" Show hidden files in result for CtrlP
let g:ctrlp_show_hidden = 1

" Lightline config to show branch and relative path fro file in status bar
let g:lightline = {
      \ 'active': {
      \   'left': [ [ 'mode', 'paste' ], [ 'readonly', 'relativepath', 'modified' ] ],
      \   'right': [ ['gitbranch'],
      \				 [ 'lineinfo' ],
      \              [ 'percent' ],
      \              [ 'filetype' ] ]
      \ },
      \	'component_function': {
      \   'gitbranch': 'FugitiveHead'
      \ },
      \ }
      
" Set contrast to high for gruvbox theme
let g:gruvbox_contrast_dark = 'hard'

" ----------------------------------------------------------------------------

" [ Editor settings ]

syntax enable
set encoding=UTF-8
set number                " set numbers in left
set autoindent            " take indent for new line from previous line
set autoread              " reload file if the file changes on the disk
set colorcolumn=80        " set colored column to 80
set cursorline            " Highlights current line
set splitbelow            " This is to set split always below the current buffer
set termguicolors         " This set just because on windows powershell theme is not working properly
set hlsearch              " Highlight searched term
set ignorecase            " Search with case-insensitive
set incsearch             " Incremental search
set mouse=a               " Disable mouse support, for now not disabled since learning, to disable use set mouse-=a
set nospell               " disable spelling
set tabstop=2             " set tab to 2 spaces
set shiftwidth=2
set expandtab             " sets tab to space when tab is pressed https://vim.fandom.com/wiki/Converting_tabs_to_spaces
set nohlsearch            " turn off the search highlighting
set scrolloff=10          " keeps 10 lines of offset at bottom while scrolling

" Theme Setting
colorscheme gruvbox

" ----------------------------------------------------------------------------

" [ Key Mappings ] [ Leader is \ by default ]

" Esc key mapping for insert and Visual mode
inoremap <C-L> <Esc>
vnoremap <C-L> <Esc>

" Normal Map 

" Hit :w on Ctrl+s
nnoremap <silent> <C-s> :w<CR>

" select all
nnoremap <leader>a ggVG

" FZF file explorer (type \{} is windows only, use cat \{} for linux and mac)
" nnoremap <silent> <C-p> :FZF --preview type\ {}<CR>
nnoremap <silent> <C-p> :Telescope find_files<CR>
nnoremap <silent> <C-f> :Telescope live_grep<CR>

" Nedtree toggle
nnoremap <silent> <C-n> :NERDTreeToggle<CR>

" To open current file in NerdTree
nnoremap <silent> <C-b> :NERDTreeFind<CR>

" Open terminal,in windows use <br> or else use pipe |
nnoremap <silent> <Leader>` :sp <bar> :terminal<CR>

" resizes current split's height to 21
nnoremap <silent> <Leader>1 :resize 21<CR>

" open newtab, this will write command , you need to type file name and then 
" press enter
nnoremap ot :tabnew
" Tab navigation
nnoremap <C-t>n :tabnext<CR>
nnoremap <C-t>p :tabprevious<CR>

" This will open defination of method or import
nmap <silent> gd <Plug>(coc-definition)
nmap <silent> gr <Plug>(coc-references)
" Open all eslint errors
nmap <silent> <Leader>cd :CocDiagnostics<CR>

" Copy to system clipboard and Paste
nnoremap <silent> <Leader>c "+y<CR>
nnoremap <silent> <Leader>v "+p<CR>

" Visual Map

" Copy to system clipboard and Paste
vnoremap <silent> <Leader>c "+y<CR>
vnoremap <silent> <Leader>v "+p<CR>
